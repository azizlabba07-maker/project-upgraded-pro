VITE_GEMINI_API_KEY=
VITE_CLAUDE_API_KEY=

# Recommended for production to avoid CORS and exposing Claude key in frontend.
# Example: https://<project-ref>.supabase.co/functions/v1/claude-proxy
VITE_CLAUDE_PROXY_URL=

# Optional shared token (must match CLAUDE_PROXY_TOKEN in Supabase secrets).
VITE_CLAUDE_PROXY_TOKEN=

# Market pulse backend (fetches live trends from Google Trends RSS).
# Example: https://<project-ref>.supabase.co/functions/v1/market-pulse
VITE_MARKET_PULSE_URL=

